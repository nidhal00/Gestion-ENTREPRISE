<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720.0" prefWidth="1160.0" styleClass="main-container" stylesheets="@../css/style.css"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gestion.controller.MainViewController">
   <children>
      <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                   AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <left>
            <VBox prefWidth="255.0" spacing="4.0" styleClass="sidebar" BorderPane.alignment="CENTER">
               <children>

                  <!-- Logo -->
                  <HBox alignment="CENTER_LEFT" spacing="12.0">
                     <children>
                        <Pane prefHeight="38.0" prefWidth="38.0"
                              style="-fx-background-color: linear-gradient(to bottom right, #6366f1, #8b5cf6); -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(99,102,241,0.5),12,0,0,0);" />
                        <VBox spacing="1.0">
                           <children>
                              <Label text="MindAudit" textFill="WHITE">
                                 <font><Font name="System Bold" size="18.0" /></font>
                              </Label>
                              <Label text="Gestion Entreprise" textFill="#475569">
                                 <font><Font size="10.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                     <VBox.margin><Insets bottom="32.0" /></VBox.margin>
                  </HBox>

                  <!-- Menu label -->
                  <Label text="MENU PRINCIPAL" textFill="#334155">
                     <font><Font name="System Bold" size="10.0" /></font>
                     <VBox.margin><Insets bottom="4.0" left="8.0" /></VBox.margin>
                  </Label>

                  <!-- Navigation buttons -->
                  <Button fx:id="btnHome" alignment="BASELINE_LEFT" mnemonicParsing="false"
                          onAction="#showHome" prefHeight="46.0" prefWidth="240.0"
                          styleClass="nav-button" text="🏠  Tableau de Bord" />
                  <Button fx:id="btnEntreprises" alignment="BASELINE_LEFT" mnemonicParsing="false"
                          onAction="#showEntreprises" prefHeight="46.0" prefWidth="240.0"
                          styleClass="nav-button" text="🏢  Entreprises" />
                  <Button fx:id="btnDocuments" alignment="BASELINE_LEFT" mnemonicParsing="false"
                          onAction="#showDocuments" prefHeight="46.0" prefWidth="240.0"
                          styleClass="nav-button" text="📄  Documents" />

                  <VBox VBox.vgrow="ALWAYS" />

                  <!-- Demo role toggle -->
                  <VBox spacing="6.0"
                        style="-fx-background-color: rgba(245,158,11,0.06); -fx-padding: 10; -fx-background-radius: 10; -fx-border-color: rgba(245,158,11,0.2); -fx-border-radius: 10; -fx-border-width: 1;">
                     <children>
                        <Label text="MODE DÉMO — BASCULER RÔLE" textFill="#92400e">
                           <font><Font size="9.0" /></font>
                        </Label>
                        <Button fx:id="btnToggleRole" mnemonicParsing="false" onAction="#handleToggleRole"
                                prefHeight="32.0" prefWidth="220.0"
                                style="-fx-background-color: rgba(245,158,11,0.15); -fx-text-fill: #fbbf24; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 11px; -fx-border-color: rgba(245,158,11,0.3); -fx-border-radius: 8; -fx-border-width: 1;"
                                text="🔄  Rôle actuel : ADMIN" />
                     </children>
                     <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                  </VBox>

                  <!-- Separator -->
                  <Pane maxHeight="1.0" prefHeight="1.0"
                        style="-fx-background-color: rgba(255,255,255,0.06);">
                     <VBox.margin><Insets bottom="10.0" /></VBox.margin>
                  </Pane>

                  <!-- User card -->
                  <HBox alignment="CENTER_LEFT" spacing="10.0"
                        style="-fx-background-color: rgba(99,102,241,0.08); -fx-padding: 12; -fx-background-radius: 12; -fx-border-color: rgba(99,102,241,0.2); -fx-border-radius: 12; -fx-border-width: 1;">
                     <children>
                        <Pane prefHeight="36.0" prefWidth="36.0"
                              style="-fx-background-color: linear-gradient(to bottom right,#4f46e5,#7c3aed); -fx-background-radius: 50%;" />
                        <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label fx:id="lblUserName" text="Admin" textFill="WHITE">
                                 <font><Font name="System Bold" size="12.0" /></font>
                              </Label>
                              <Label fx:id="lblUserRole" text="Administrateur" textFill="#6366f1">
                                 <font><Font name="System Bold" size="10.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>

               </children>
               <padding><Insets bottom="16.0" left="12.0" right="12.0" top="24.0" /></padding>
            </VBox>
         </left>

         <center>
            <VBox BorderPane.alignment="CENTER">
               <children>
                  <!-- Topbar -->
                  <HBox alignment="CENTER_LEFT" prefHeight="64.0" spacing="16.0" styleClass="topbar">
                     <children>
                        <VBox>
                           <children>
                              <Label fx:id="lblPageTitle" text="Tableau de Bord" textFill="WHITE">
                                 <font><Font name="System Bold" size="17.0" /></font>
                              </Label>
                              <Label fx:id="lblPageSubtitle" text="Vue d'ensemble" textFill="#475569">
                                 <font><Font size="11.0" /></font>
                              </Label>
                           </children>
                        </VBox>
                        <Pane HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblRoleBadge" text="ADMIN"
                               style="-fx-background-color: rgba(99,102,241,0.15); -fx-text-fill: #818cf8; -fx-font-weight: bold; -fx-font-size: 10px; -fx-background-radius: 6; -fx-padding: 4 10; -fx-border-color: rgba(99,102,241,0.3); -fx-border-radius: 6; -fx-border-width: 1;" />
                     </children>
                  </HBox>

                  <!-- Content area -->
                  <StackPane fx:id="contentArea" style="-fx-background-color: #0a0f1e;" VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </center>
      </BorderPane>
   </children>
</AnchorPane>
