<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="656.0" prefWidth="905.0" style="-fx-background-color: #0a0f1e;"
            stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gestion.controller.DocumentController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <HBox fx:id="adminControlsDoc" alignment="CENTER_LEFT" spacing="10.0"
                  style="-fx-background-color: rgba(26,34,54,0.6); -fx-padding: 10 20; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10;">
               <children>
                  <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="PANNEAU ADMINISTRATEUR" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleValidateDoc" prefHeight="36.0"
                          style="-fx-background-color: linear-gradient(to bottom right,#059669,#10b981); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"
                          text="✅  Valider" />
                  <Button mnemonicParsing="false" onAction="#handleRejectDoc" prefHeight="36.0"
                          style="-fx-background-color: linear-gradient(to bottom right,#991b1b,#dc2626); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"
                          text="❌  Rejeter" />
               </children>
            </HBox>

            <HBox fx:id="filterBar" alignment="CENTER_LEFT" spacing="12.0" styleClass="filter-bar">
               <children>
                  <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px; -fx-font-weight: bold;" text="🔍  Filtrer par entreprise :" />
                  <ComboBox fx:id="cbFilter" prefHeight="34.0" prefWidth="240.0" promptText="Toutes les entreprises" onAction="#handleFilter" />
                  <Button mnemonicParsing="false" onAction="#handleClearFilter" prefHeight="34.0" styleClass="btn-secondary" text="↺" />
               </children>
            </HBox>

            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox prefWidth="360.0" spacing="16.0" styleClass="card">
                     <children>
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="card-title" text="Dépôt de Document" />
                              <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="Renseignez les métadonnées du fichier" />
                           </children>
                        </VBox>
                        <Pane maxHeight="1.0" prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.06);" />

                        <VBox spacing="14.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label style="-fx-text-fill: #94a3b8;" text="Entreprise concernée *" />
                                    <ComboBox fx:id="cbEntreprise" prefHeight="38.0" prefWidth="320.0" promptText="Sélectionner l'entreprise" />
                                    <Label fx:id="errEntreprise" styleClass="error-label" visible="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label style="-fx-text-fill: #94a3b8;" text="Libellé du document *" />
                                    <TextField fx:id="txtNom" prefHeight="38.0" promptText="Ex: Contrat de travail 2025" />
                                    <Label fx:id="errNom" styleClass="error-label" visible="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label style="-fx-text-fill: #94a3b8;" text="Catégorie" />
                                    <ComboBox fx:id="cbType" prefHeight="38.0" prefWidth="320.0" promptText="Sélectionner une catégorie" />
                                    <Label fx:id="errType" styleClass="error-label" visible="false" />
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label style="-fx-text-fill: #94a3b8;" text="Chemin du fichier *" />
                                    <HBox spacing="8.0">
                                       <children>
                                          <TextField fx:id="txtUrl" editable="false" prefHeight="38.0"
                                                      promptText="Parcourir ou coller un chemin..."
                                                      style="-fx-opacity: 0.85;" HBox.hgrow="ALWAYS" />
                                          <Button mnemonicParsing="false" onAction="#handleBrowse"
                                                   prefHeight="38.0" prefWidth="38.0"
                                                   styleClass="btn-secondary" text="📁" />
                                       </children>
                                    </HBox>
                                    <Label fx:id="errUrl" styleClass="error-label" visible="false" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#clearFields" styleClass="btn-secondary" text="↺ Annuler" />
                              <Button mnemonicParsing="false" onAction="#handleSave" styleClass="btn-primary" text="💾  Enregistrer" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <VBox spacing="14.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="card-title" text="Archive de Documents" />
                              <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="Sélectionnez un document pour l'éditer ou le valider" />
                           </children>
                        </VBox>
                        <Pane maxHeight="1.0" prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.06);" />
                        <TableView fx:id="tableDocuments" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colNom"    prefWidth="155.0" text="Document" />
                            <TableColumn fx:id="colType"   prefWidth="80.0"  text="Catégorie" />
                            <TableColumn fx:id="colStatut" prefWidth="90.0"  text="Statut" />
                            <TableColumn fx:id="colDate"   prefWidth="120.0" text="Date" />
                            <TableColumn fx:id="colUrl"    prefWidth="120.0" text="Localisation" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                        <HBox alignment="CENTER_RIGHT">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-danger" text="🗑️  Supprimer" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
         <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
      </VBox>
   </children>
</AnchorPane>
