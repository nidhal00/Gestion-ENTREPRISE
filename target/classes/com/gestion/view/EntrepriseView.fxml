<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="656.0" prefWidth="905.0" style="-fx-background-color: #0a0f1e;"
            stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.gestion.controller.EntrepriseController">
   <children>
      <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- Panneau administrateur -->
            <HBox fx:id="adminControls" alignment="CENTER_RIGHT" spacing="10.0"
                  style="-fx-background-color: rgba(26,34,54,0.6); -fx-padding: 10 20; -fx-background-radius: 10; -fx-border-color: rgba(255,255,255,0.05); -fx-border-radius: 10;">
               <children>
                  <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;" text="PANNEAU ADMINISTRATEUR" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleValidate" prefHeight="36.0"
                          style="-fx-background-color: linear-gradient(to right, #059669, #10b981); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"
                          text="✅  Valider" />
                  <Button mnemonicParsing="false" onAction="#handleInvalidate" prefHeight="36.0"
                          style="-fx-background-color: linear-gradient(to right, #991b1b, #dc2626); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 8 20;"
                          text="❌  Invalider" />
               </children>
            </HBox>

            <!-- Contenu principal -->
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>

                  <!-- ══ Formulaire ══ -->
                  <VBox prefWidth="385.0" spacing="18.0" styleClass="card">
                     <children>

                        <!-- En-tête formulaire -->
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="card-title" text="Informations de l'entreprise" />
                              <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;"
                                     text="Remplissez les champs puis cliquez sur Enregistrer" />
                           </children>
                        </VBox>
                        <Pane maxHeight="1.0" prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.06);" />

                        <ScrollPane fitToWidth="true" focusTraversable="false" prefHeight="430.0"
                                    style="-fx-background-color: transparent; -fx-background: transparent;">
                           <content>
                              <GridPane hgap="14.0" vgap="14.0">
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
                                 </rowConstraints>
                                 <children>

                                    <!-- Nom -->
                                    <VBox spacing="5.0" GridPane.columnSpan="2">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Nom de l'entreprise *" />
                                          <TextField fx:id="txtNom" prefHeight="38.0" promptText="Ex: MindAudit Consulting" />
                                          <Label fx:id="errNom" styleClass="error-label" visible="false" />
                                       </children>
                                    </VBox>

                                    <!-- Matricule Fiscale -->
                                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="1">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Matricule Fiscale *" />
                                          <TextField fx:id="txtMatricule" prefHeight="38.0" promptText="Ex: 1234567A  ou  1234567A/P/M/000" />
                                          <Label fx:id="errMatricule" styleClass="error-label" visible="false" />
                                       </children>
                                    </VBox>

                                    <!-- Secteur (ComboBox) -->
                                    <VBox spacing="5.0" GridPane.rowIndex="2">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Secteur d'activité" />
                                          <ComboBox fx:id="cbSecteur" prefHeight="38.0" prefWidth="175.0"
                                                    promptText="Choisir un secteur" />
                                       </children>
                                    </VBox>

                                    <!-- Taille -->
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Taille" />
                                          <ComboBox fx:id="cbTaille" prefHeight="38.0" prefWidth="160.0"
                                                    promptText="Choisir" />
                                       </children>
                                    </VBox>

                                    <!-- Email -->
                                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="3">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Email professionnel *" />
                                          <TextField fx:id="txtEmail" prefHeight="38.0" promptText="contact@entreprise.tn" />
                                          <Label fx:id="errEmail" styleClass="error-label" visible="false" />
                                       </children>
                                    </VBox>

                                    <!-- Pays -->
                                    <VBox spacing="5.0" GridPane.rowIndex="4">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Pays" />
                                          <TextField fx:id="txtPays" prefHeight="38.0" promptText="Tunisie" />
                                       </children>
                                    </VBox>

                                    <!-- Téléphone -->
                                    <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Téléphone (8 chiffres) *" />
                                          <TextField fx:id="txtTelephone" prefHeight="38.0" promptText="Ex: 71234567" />
                                          <Label fx:id="errTelephone" styleClass="error-label" visible="false" />
                                       </children>
                                    </VBox>

                                    <!-- Date de création -->
                                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="5">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Date de création" />
                                          <DatePicker fx:id="dpDateCreation" prefHeight="38.0" prefWidth="340.0"
                                                      promptText="Sélectionner une date" />
                                       </children>
                                    </VBox>

                                    <!-- Adresse -->
                                    <VBox spacing="5.0" GridPane.columnSpan="2" GridPane.rowIndex="6">
                                       <children>
                                          <Label style="-fx-text-fill: #94a3b8;" text="Adresse complète" />
                                          <TextField fx:id="txtAdresse" prefHeight="38.0" promptText="Rue, Ville, Code Postal" />
                                       </children>
                                    </VBox>

                                 </children>
                              </GridPane>
                           </content>
                        </ScrollPane>

                        <!-- Boutons action -->
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                           <children>
                              <Button mnemonicParsing="false" onAction="#clearFields"
                                      styleClass="btn-secondary" text="↺ Réinitialiser" />
                              <Button mnemonicParsing="false" onAction="#handleSave"
                                      styleClass="btn-primary" text="💾 Enregistrer" />
                           </children>
                        </HBox>

                     </children>
                  </VBox>

                  <!-- ══ Table ══ -->
                  <VBox spacing="14.0" styleClass="card" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                           <children>
                              <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label styleClass="card-title" text="Portefeuille Clients" />
                                    <Label style="-fx-text-fill: #475569; -fx-font-size: 11px;"
                                           text="Cliquez sur une ligne pour la modifier" />
                                 </children>
                              </VBox>
                              <TextField fx:id="txtSearch" prefHeight="35.0" prefWidth="250.0"
                                         promptText="🔍 Rechercher..." />
                           </children>
                        </HBox>
                        <Pane maxHeight="1.0" prefHeight="1.0" style="-fx-background-color: rgba(255,255,255,0.06);" />

                        <TableView fx:id="tableEntreprises" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="colNom"        prefWidth="130.0" text="Entreprise" />
                              <TableColumn fx:id="colMatricule"  prefWidth="120.0" text="Matricule" />
                              <TableColumn fx:id="colSecteur"    prefWidth="120.0" text="Secteur" />
                              <TableColumn fx:id="colStatut"     prefWidth="80.0"  text="Statut" />
                              <TableColumn fx:id="colCompliance" prefWidth="80.0"  text="Conformité" />
                           </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>

                        <HBox alignment="CENTER_RIGHT">
                           <children>
                              <Button mnemonicParsing="false" onAction="#handleDelete"
                                      styleClass="btn-danger" text="🗑️  Supprimer la sélection" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

               </children>
            </HBox>

         </children>
         <padding><Insets bottom="20.0" left="24.0" right="24.0" top="20.0" /></padding>
      </VBox>
   </children>
</AnchorPane>
